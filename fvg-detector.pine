//@version=6
// -------------------------------------------------------------------
//  FVG Detector
//  v1.2.2
// -------------------------------------------------------------------
indicator(title="FVG Detector", shorttitle="FVG", overlay=true, max_bars_back=500, max_boxes_count=500, max_lines_count=500)

// === Inputs ===
grp_display = "Display Settings"
bullColor   = input.color(color.new(#a8c500, 75), "Bullish FVG Color",   group=grp_display)
bearColor   = input.color(color.new(#ff60a0, 75), "Bearish FVG Color",   group=grp_display)
showMidline = input.bool(true, "Show Middle Line", group=grp_display)
grp_layout  = "Geometry & Filters"
boxWidth    = input.int(1, "Box Width (Bars)", minval=1, step=1, group=grp_layout)
minGapPct   = input.float(45, "Min Gap Size (%)", minval=0, maxval=1000, step=5, 
              tooltip="Gap must be at least this % of displacement candle body. \nExamples: \n45 = 45% (recommended) \n10 = 10% (more gaps) \n0 = To show all gaps (no filter)", 
              group=grp_layout) / 100

// === Calculations ===
bool isBullishFVG = low > high[2]
bool isBearishFVG = high < low[2]
float triggerBody = math.abs(close[1] - open[1])  // Use middle (impulse) candle as trigger
float bullGapSize = isBullishFVG ? (low - high[2]) : 0.0
float bearGapSize = isBearishFVG ? (low[2] - high) : 0.0
bool validBull = isBullishFVG and (minGapPct == 0 or (triggerBody > 0 ? bullGapSize >= triggerBody * minGapPct : true))
bool validBear = isBearishFVG and (minGapPct == 0 or (triggerBody > 0 ? bearGapSize >= triggerBody * minGapPct : true))

// === Plot ===
if validBull
    float top    = low
    float bottom = high[2]
    float avg    = math.avg(top, bottom)
    int   left   = bar_index - 1
    int   right  = left + boxWidth
    box.new(left, top, right, bottom, border_color=na, bgcolor=bullColor)
    if showMidline
        line.new(left, avg, right, avg, color=bullColor, width=3)
if validBear
    float top    = low[2]
    float bottom = high
    float avg    = math.avg(top, bottom)
    int   left   = bar_index - 1
    int   right  = left + boxWidth
    box.new(left, top, right, bottom, border_color=na, bgcolor=bearColor)
    if showMidline
        line.new(left, avg, right, avg, color=bearColor, width=3)